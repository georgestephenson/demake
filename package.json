{
  "name": "demake-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Convert any image into hardware-compliant art and displayable code for 8/16-bit-era consoles and handhelds up to the Nintendo DS.",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc --build",
    "build:web": "pnpm --filter @demake/web build",
    "clean": "tsc --build --clean",
    "typecheck": "tsc --build",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:web": "pnpm --filter @demake/web dev",
    "test:browser": "pnpm --filter @demake/web test:e2e",
    "check:web-budget": "pnpm build:web && node tools/ci/check-web-budget.mjs",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "changeset": "changeset",
    "cli": "node packages/cli/dist/index.js",
    "gen:man": "pnpm --filter demake gen:man",
    "eval:prep": "node tools/prep-eval/run.mjs",
    "toolchains": "bash tools/toolchains/install-rgbds.sh && bash tools/toolchains/install-cc65.sh && bash tools/toolchains/install-wladx.sh && bash tools/toolchains/install-m68k.sh && bash tools/toolchains/install-arm.sh",
    "emulator": "bash tools/toolchains/install-sameboy.sh && bash tools/toolchains/install-libretro.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.6",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
